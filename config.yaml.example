# Nova Agent Configuration

# OpenRouter API
openrouter:
  api_key: "${OPENROUTER_API_KEY}"  # or set OPENROUTER_API_KEY env var
  model: "qwen/qwen3.6-flash"       # Fast, capable, affordable
  base_url: "https://openrouter.ai/api/v1"

# Agent settings
agent:
  identity: "You are Nova, a helpful personal assistant."
  max_iterations: 50          # Max tool calls per turn
  temperature: 0.7
  top_p: 1.0

# Token budgets (explicit caps at every layer)
budgets:
  system_prompt_max: 8000           # Total system prompt tokens
  skills_max_chars: 15000           # Skills section character limit
  skills_max_count: 50              # Max skills in prompt
  context_file_max_chars: 10000     # Per context file
  context_total_max_chars: 50000    # Total across all context files
  tool_result_max_chars: 8000       # Per tool result
  conversation_turn_limit: 15       # DM session turn limit before compression

# Context compression
compression:
  enabled: true
  threshold_percent: 0.40    # Compress at 40% of context window
  summary_model: "qwen/qwen3.6-flash"  # Cheap model for summarization
  reserve_tokens: 15000      # Reserve for compaction overhead

# Context files to discover (in priority order)
context_files:
  - ".nova.md"
  - "NOVA.md"
  - "AGENTS.md"
  - "SOUL.md"
  - "CLAUDE.md"
  - ".cursorrules"

# Memory
memory:
  enabled: true
  max_entries: 100
  file: "~/.nova/memory.json"

# Skills
skills:
  enabled: true
  directory: "~/.nova/skills"

# Session storage
session:
  enabled: true
  directory: "~/.nova/sessions"

# Logging
logging:
  level: "INFO"
  file: "~/.nova/nova.log"

# Sub-agent delegation
# Allows the agent to spawn child agents for isolated or parallelizable tasks.
delegation:
  enabled: false                  # Set to true to enable delegate_task tool
  max_spawn_depth: 2              # Max nesting depth (0=root only, 2=root→child→grandchild)
  default_timeout_seconds: 60     # Default sub-agent timeout

  # Budget overrides for sub-agents (smaller than parent defaults)
  subagent_budgets:
    max_iterations: 30            # Max tool calls per sub-agent turn
    system_prompt_max: 4000       # Smaller system prompt for sub-agents
    tool_result_max_chars: 4000   # Smaller tool result budget

# Permission system — tool execution approval with defense-in-depth
# Modes: "auto" (allow all, current default) or "ask" (confirm mutating tools)
permissions:
  mode: "auto"                    # "auto" or "ask"
  denied_tools: []                # Tools the agent can never use
  allowed_tools: []               # Tools that bypass confirmation (ask mode)
  denied_commands:                # Shell command patterns that are always blocked
    - "rm -rf /"
    - "rm -rf /*"
    - ":(){*};:*"                 # Fork bomb
  path_rules: []                  # Path-level allow/deny rules (fnmatch patterns)
    # Example:
    # - pattern: "/etc/*"
    #   allow: false

# MCP (Model Context Protocol) — connect to external tool servers
# Supports three transport types: stdio (local), http (Streamable HTTP), sse (Server-Sent Events)
mcp:
  servers: {}
    # Example: Local filesystem server (stdio — default when command is present)
    # filesystem:
    #   type: stdio
    #   command: npx
    #   args: ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]

    # Example: Remote API server (Streamable HTTP)
    # remote-api:
    #   type: http
    #   url: https://api.example.com/mcp
    #   headers:
    #     Authorization: "Bearer ${API_TOKEN}"
    #   timeout: 30.0

    # Example: SSE-based server
    # sse-server:
    #   type: sse
    #   url: https://api.example.com/sse
    #   post_url: https://api.example.com/post  # optional, defaults to url
    #   headers:
    #     Authorization: "Bearer ${API_TOKEN}"
    #   timeout: 30.0

    # Example: GitHub server (stdio with env vars)
    # github:
    #   type: stdio
    #   command: npx
    #   args: ["-y", "@modelcontextprotocol/server-github"]
    #   env:
    #     GITHUB_PERSONAL_ACCESS_TOKEN: "${GITHUB_TOKEN}"

# Cost tracking — token counts and dollar costs per session
cost_tracking:
  enabled: true                   # Track usage and estimate costs

# Microcompact — cheap context window reduction (Tier 1 compaction)
# Strips old tool result content while preserving message structure
microcompact:
  enabled: true                   # Enable microcompact before LLM-based compression
  keep_recent: 6                  # Number of recent messages to preserve fully
